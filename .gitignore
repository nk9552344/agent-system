# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
.eggs/

# ─── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

