.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─── Testing / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
/tmp/pytest_*.json

# ─── Type checkers / linters ──────────────────────────────────────────────────
