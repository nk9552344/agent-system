# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
*.env
!.env.example

# ─── LanceDB data — managed externally, never committed ──────────────────────
data/lancedb/
data/*.db
data/*.lance/

# ─── Git worktrees — created at runtime by coordinator / researcher ───────────
.agent-worktrees/

# ─── Research artefacts ───────────────────────────────────────────────────────
research_log.txt

